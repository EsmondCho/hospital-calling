# Local secrets / overrides (never commit real values)
# The trailing `*` also covers the `.env.local.secrets.tmp` written by
# `make proddb-env` mid-write — a SIGKILL before its `mv` must not leave
# prod credentials in a git-trackable file.
.local-setup/.env.local.secrets*
.local-setup/.env.local.local
.local-setup/.env.prod.local

