ENV=local
DJANGO_SETTINGS_MODULE=hospcall.settings

# --- Datastore (provided by docker-compose: postgres + redis services) ---
DB_NAME=hospcall
DB_USER=hospcall
DB_PASSWORD=hospcall
DB_HOST=postgres
DB_PORT=5432

REDIS_URL=redis://redis:6379/0

# --- Django ---
SECRET_KEY=local-dev-secret-key-not-for-production
ALLOWED_HOSTS=*
DEBUG=True

# Backoffice write-API token. The Next.js proxy sends this as the
# `x-backoffice-token` header on every mutating request; without a match every
# write returns 401. Local-dev value only — not a secret.
BACKOFFICE_API_TOKEN=local-dev-token

# --- External APIs (LEAVE BLANK to run the read-only demo) -----------------
# Fill these in (here or in the repo-root .env) to enable the live features
# they power. Empty values keep the app fully bootable — seeded data renders,
# but live actions no-op / return a clear error.
#   GOOGLE_PLACES_API_KEY → hospital sourcing (scrape clinics from Google)
#   ANTHROPIC_API_KEY     → Claude classification of sourced hospitals
#   BLANDAI_API_KEY       → placing the actual outbound phone calls
# docker-compose overrides these from the repo-root .env when set there.
GOOGLE_PLACES_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

BLANDAI_API_KEY=
BLANDAI_BASE_URL=https://api.bland.ai/v1
BLANDAI_DEFAULT_VOICE=maya
BLANDAI_DEFAULT_MODEL=base
BLANDAI_DEFAULT_LANGUAGE=en
BLANDAI_MAX_DURATION=5
BLANDAI_WEBHOOK_URL=
BLANDAI_WEBHOOK_SECRET=

# Calling defaults
CALLING_TIMEZONE=America/Los_Angeles
