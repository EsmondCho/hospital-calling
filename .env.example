# Copy to `.env` and fill in keys ONLY if you want to exercise the live
# features. The demo runs fully without any of them — seeded data renders and
# the whole UI is browsable read-only.
#
#   cp .env.example .env
#
# ── External API keys (optional) ───────────────────────────────────────────
# Google Places — powers "Sourcing" (scraping vet clinics from Google).
GOOGLE_PLACES_API_KEY=

# Anthropic (Claude) — classifies each sourced hospital (ownership / tags).
ANTHROPIC_API_KEY=

# Bland.ai — places the actual outbound phone calls when a schedule fires.
# NOTE: seeded hospital phone numbers are fictitious (555-01xx) on purpose, so
# enabling this will not dial real clinics.
BLANDAI_API_KEY=

# ── Backoffice login (optional override) ───────────────────────────────────
# "user:password" pairs, comma-separated. Defaults to demo:hospcall2026.
BASIC_AUTH_USERS=demo:hospcall2026
# Any random string ≥16 chars (signs the session cookie).
SESSION_SECRET=demo-session-secret-change-me-please
