# Local dev only. Loaded by `next dev`, NOT by production builds — Vercel
# supplies its own BACKOFFICE_API_TOKEN env var for the deployed app.
#
# The /api/proxy route forwards this as the `x-backoffice-token` header to
# hospcall-server; without it every write (create/edit/delete) returns 401. Must
# match the `BACKOFFICE_API_TOKEN` in hospcall-server's `.local-setup/.env.local`.
BACKOFFICE_API_TOKEN=local-dev-token
